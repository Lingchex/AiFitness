
.kb-container.data-v-2353aac3 {
  min-height: 100vh;
  background-color: #F8FAFC;
  overflow-x: hidden;
}

/* ========== 背景装饰 ========== */
.header-bg-decor.data-v-2353aac3 {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 480rpx;
  z-index: 0;
  overflow: hidden;
  pointer-events: none;
}
.decor-circle.data-v-2353aac3 {
  position: absolute;
  border-radius: 50%;
  opacity: 0.07;
  background: #fff;
}
.c1.data-v-2353aac3 { width: 300rpx; height: 300rpx; top: -100rpx; right: -50rpx;
}
.c2.data-v-2353aac3 { width: 180rpx; height: 180rpx; top: 220rpx; left: -40rpx;
}
.c3.data-v-2353aac3 { width: 100rpx; height: 100rpx; top: 60rpx; left: 200rpx;
}

/* ========== 头部 ========== */
.kb-header.data-v-2353aac3 {
  position: relative;
  z-index: 1;
  background: linear-gradient(160deg, #1e293b 0%, #334155 100%);
  padding: 100rpx 40rpx 60rpx;
  border-bottom-left-radius: 56rpx;
  border-bottom-right-radius: 56rpx;
}
.header-top.data-v-2353aac3 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}
.page-title-wrap.data-v-2353aac3 {
  display: flex;
  flex-direction: column;
}
.page-title.data-v-2353aac3 {
  font-size: 48rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}
.page-subtitle.data-v-2353aac3 {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}
.upload-btn.data-v-2353aac3 {
  background: #3b82f6 !important;
  width: auto !important;
  height: 72rpx !important;
  padding: 0 28rpx;
  border-radius: 36rpx !important;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.upload-text.data-v-2353aac3 {
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}
.action-icon.data-v-2353aac3 {
  font-size: 28rpx;
}
.search-bar.data-v-2353aac3 {
  background: rgba(255, 255, 255, 0.12);
  height: 84rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}
.search-icon.data-v-2353aac3 {
  font-size: 30rpx;
  margin-right: 20rpx;
  opacity: 0.7;
}
.search-bar input.data-v-2353aac3 {
  color: #FFF;
  font-size: 28rpx;
  flex: 1;
}

/* ========== Tab 切换 (优化版) ========== */
.tabs-card.data-v-2353aac3 {
  position: relative;
  z-index: 2;
  margin: -32rpx 40rpx 0;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 10rpx;
  display: flex;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.05);
}
.tab-item.data-v-2353aac3 {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10rpx;
  padding: 22rpx 0;
  position: relative;
  z-index: 2;
}
.tab-text.data-v-2353aac3 {
  font-size: 28rpx;
  color: #64748b;
  font-weight: 500;
  transition: all 0.3s;
}
.tab-count.data-v-2353aac3 {
  font-size: 20rpx;
  color: #94a3b8;
  background: #f1f5f9;
  padding: 2rpx 14rpx;
  border-radius: 100rpx;
  font-weight: 600;
}
.tab-item.active .tab-text.data-v-2353aac3 {
  color: #1e293b;
  font-weight: 700;
}
.active-count.data-v-2353aac3 {
  color: #3b82f6 !important;
  background: rgba(59, 130, 246, 0.1) !important;
}

/* 滑动条容器 */
.tab-indicator-bar.data-v-2353aac3 {
  position: absolute;
  bottom: 12rpx;
  left: 10rpx;
  right: 10rpx;
  height: 6rpx;
  pointer-events: none;
}
/* 具体的滑动指示器线段 */
.tab-indicator.data-v-2353aac3 {
  width: 33.33%;
  height: 100%;
  display: flex;
  justify-content: center;
  transition: transform 0.3s cubic-bezier(0.65, 0, 0.35, 1);
}
.tab-indicator.data-v-2353aac3::after {
  content: '';
  width: 40rpx; /* 线段宽度 */
  height: 100%;
  background: #3b82f6;
  border-radius: 10rpx;
}

/* ========== 文档列表 ========== */
.book-scroll.data-v-2353aac3 {
  height: calc(100vh - 420rpx);
}
.book-list.data-v-2353aac3 {
  display: flex;
  flex-wrap: wrap;
  padding: 32rpx 32rpx 0;
  justify-content: space-between;
}
.book-card.data-v-2353aac3 {
  width: 47.5%;
  background: #FFFFFF;
  border-radius: 32rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(0, 0, 0, 0.02);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}
.card-hover.data-v-2353aac3 {
  transform: translateY(-8rpx);
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.08);
}
.book-cover-box.data-v-2353aac3 {
  height: 200rpx;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}
.cover-pattern.data-v-2353aac3 {
  position: absolute;
  inset: 0;
  opacity: 0.12;
  display: flex;
  flex-direction: column;
  justify-content: space-evenly;
  padding: 24rpx;
}
.pattern-line.data-v-2353aac3 {
  height: 6rpx;
  border-radius: 6rpx;
  background: #fff;
}
.pattern-line.data-v-2353aac3:nth-child(1) { width: 40%;
}
.pattern-line.data-v-2353aac3:nth-child(2) { width: 70%;
}
.pattern-line.data-v-2353aac3:nth-child(3) { width: 50%;
}
.cover-emoji.data-v-2353aac3 {
  font-size: 80rpx;
  z-index: 1;
}
.file-type-tag.data-v-2353aac3 {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: rgba(0, 0, 0, 0.2);
  -webkit-backdrop-filter: blur(4px);
          backdrop-filter: blur(4px);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.file-type-text.data-v-2353aac3 {
  font-size: 18rpx;
  color: #fff;
  font-weight: 700;
}
.book-info.data-v-2353aac3 {
  padding: 24rpx;
}
.book-title.data-v-2353aac3 {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  height: 78rpx; /* 保持高度一致 */
  margin-bottom: 16rpx;
}
.book-meta.data-v-2353aac3 {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.meta-left.data-v-2353aac3 {
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.meta-size.data-v-2353aac3, .meta-pages.data-v-2353aac3 {
  font-size: 20rpx;
  color: #94a3b8;
}
.meta-dot.data-v-2353aac3 {
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: #cbd5e1;
}
.meta-source.data-v-2353aac3 {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 18rpx;
  font-weight: 600;
}
.source-official.data-v-2353aac3 { background: #f1f5f9; color: #475569;
}
.source-user.data-v-2353aac3 { background: #eff6ff; color: #3b82f6;
}

/* ========== 空状态 ========== */
.empty-hint.data-v-2353aac3 {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
}
.empty-emoji.data-v-2353aac3 {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  filter: grayscale(1);
  opacity: 0.5;
}
.empty-text.data-v-2353aac3 {
  font-size: 28rpx;
  color: #94a3b8;
}
