/* ========== 用户头部 ========== */
.user-header.data-v-0f7520f0 {
  position: relative;
  z-index: 1;
  height: 520rpx;
  background: linear-gradient(160deg, #0F2027 0%, #203A43 40%, #2C5364 100%);
  padding: 100rpx 48rpx 0;
  box-sizing: border-box;
  border-bottom-left-radius: 56rpx;
  border-bottom-right-radius: 56rpx;
  overflow: hidden;
}
.header-actions.data-v-0f7520f0 {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-bottom: 50rpx;
}
.action-btn.data-v-0f7520f0 {
  position: relative;
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  -webkit-backdrop-filter: blur(10px);
          backdrop-filter: blur(10px);
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.2s;
}
.action-hover.data-v-0f7520f0 {
  background: rgba(255, 255, 255, 0.22);
  transform: scale(0.95);
}
.action-icon.data-v-0f7520f0 {
  font-size: 34rpx;
}
.dot-badge.data-v-0f7520f0 {
  position: absolute;
  top: 10rpx;
  right: 12rpx;
  width: 14rpx;
  height: 14rpx;
  background: #FF6B6B;
  border-radius: 50%;
  border: 2rpx solid rgba(15, 32, 39, 0.6);
}
.user-info.data-v-0f7520f0 {
  display: flex;
  align-items: center;
}

/* 头像 */
.avatar-wrapper.data-v-0f7520f0 {
  position: relative;
  flex-shrink: 0;
}
.avatar.data-v-0f7520f0 {
  width: 136rpx;
