/* ===== 新增：分析中脉冲动画 ===== */
.analyzing-wrap.data-v-53b1e711 {
	position: relative;
	display: flex;
	align-items: center;
	justify-content: center;
	width: 100%;
	height: 100%;
	z-index: 1;
}
.pulse-ring.data-v-53b1e711 {
	position: absolute;
	width: 60rpx;
	height: 60rpx;
	border: 4rpx solid rgba(255,255,255,0.6);
	border-radius: 50%;
	animation: pulse-expand-53b1e711 2s ease-out infinite;
}
.pulse-ring.delay.data-v-53b1e711 {
	animation-delay: 0.5s;
}
.analyzing-text.data-v-53b1e711 {
	position: relative;
	z-index: 2;
	font-size: 28rpx;
	letter-spacing: 2rpx;
}
@keyframes pulse-expand-53b1e711 {
0% { transform: scale(0.5); opacity: 1;
}
100% { transform: scale(2.5); opacity: 0;
}
}

